generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  PENDING_REVIEW
  ACTIVE
  REJECTED
  MUTED
  BANNED
  DISABLED
  PENDING_DELETION
}

enum UserRole {
  USER
  SUPER_ADMIN
}

enum DirectMessagePermission {
  EVERYONE
  FOLLOWING_ONLY
  DISABLED
}

enum HomeFeedChannel {
  RECOMMENDED
  HOT
  NEWEST
  FOLLOWING
}

enum CircleStatus {
  PENDING_REVIEW
  ACTIVE
  REJECTED
  ARCHIVED
  DISABLED
}

enum CircleManagerRole {
  OWNER
  MANAGER
}

enum WorkflowStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PostType {
  DISCUSSION
  QUESTION
  EXPERIENCE
  ANNOUNCEMENT
  POLL
}

enum ContentStatus {
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  DELETED
  BLOCKED
}

enum ContentVisibility {
  PUBLIC
}

enum TagScope {
  GLOBAL
  CIRCLE
}

enum AttachmentKind {
  IMAGE
  GIF
  DOCUMENT
  ARCHIVE
}

enum ReactionTargetType {
  POST
  COMMENT
}

enum ReactionType {
  LIKE
  EMOJI
}

enum PollResultVisibility {
  ALWAYS_PUBLIC
  AFTER_VOTE
}

enum ConversationType {
  DIRECT
  SYSTEM
}

enum MessageType {
  TEXT
  EMOJI
  IMAGE
  GIF
}

enum NotificationType {
  LIKE
  COMMENT
  REPLY
  FOLLOW
  MENTION
  DIRECT_MESSAGE
  REGISTRATION_REVIEW
  CONTENT_REVIEW
  SYSTEM
}

enum ReportType {
  SEXUAL
  PERSONAL_ATTACK
  ADVERTISEMENT
  ILLEGAL
  SPAM
  COPYRIGHT
  OTHER
}

enum ReportStatus {
  PENDING
  PROCESSING
  RESOLVED
  REJECTED
}

enum ReportTargetType {
  POST
  COMMENT
  USER
  CIRCLE
  MESSAGE
}

enum ModerationActionType {
  APPROVE_REGISTRATION
  REJECT_REGISTRATION
  APPROVE_CIRCLE
  REJECT_CIRCLE
  APPROVE_CONTENT
  REJECT_CONTENT
  DELETE_POST
  DELETE_COMMENT
  MUTE_USER
  UNMUTE_USER
  BAN_USER
  UNBAN_USER
  PIN_POST
  FEATURE_POST
  RECOMMEND_POST
  HANDLE_REPORT
  ADJUST_POINTS
}

enum SensitiveWordLevel {
  SEVERE
  SUSPECT
  GENERAL
}

enum SensitiveWordAction {
  BLOCK
  REVIEW
  WARN
}

enum PointEventType {
  POST_CREATE
  COMMENT_CREATE
  RECEIVE_LIKE
  RECEIVE_FAVORITE
  MANUAL_ADJUST
}

enum BadgeKind {
  BADGE
  TITLE
}

enum BannerStatus {
  DRAFT
  ACTIVE
  INACTIVE
  EXPIRED
}

enum RecommendationSlotType {
  HOMEPAGE_BANNER
  HOMEPAGE_RECOMMENDED_CIRCLE
  HOMEPAGE_ACTIVITY
  HOMEPAGE_TOPIC
  SQUARE_RECOMMENDATION
  DISCOVER_HOT
}

enum RecommendationTargetType {
  POST
  CIRCLE
  ACTIVITY
  URL
  TOPIC
}

model User {
  id                   String                    @id @default(cuid())
  username             String                    @unique
  email                String                    @unique
  passwordHash         String                    @map("password_hash")
  status               UserStatus                @default(PENDING_REVIEW)
  role                 UserRole                  @default(USER)
  reviewNote           String?                   @map("review_note")
  reviewedAt           DateTime?                 @map("reviewed_at")
  reviewedById         String?                   @map("reviewed_by_id")
  mutedUntil           DateTime?                 @map("muted_until")
  bannedAt             DateTime?                 @map("banned_at")
  disabledAt           DateTime?                 @map("disabled_at")
  deletionRequestedAt  DateTime?                 @map("deletion_requested_at")
  lastLoginAt          DateTime?                 @map("last_login_at")
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")
  profile              UserProfile?
  settings             UserSetting?
  reviewedBy           User?                     @relation("UserReviewers", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedUsers        User[]                    @relation("UserReviewers")
  following            UserFollow[]              @relation("FollowingRelations")
  followers            UserFollow[]              @relation("FollowerRelations")
  blockedUsers         UserBlock[]               @relation("BlockingRelations")
  blockedByUsers       UserBlock[]               @relation("BlockedByRelations")
  ownedCircles         Circle[]                  @relation("CircleOwner")
  managedCircles       CircleManagerRelation[]   @relation("CircleManagerUser")
  grantedCircleRoles   CircleManagerRelation[]   @relation("CircleManagerGrantedBy")
  circleApplications   CircleApplication[]       @relation("CircleApplicationApplicant")
  reviewedApplications CircleApplication[]       @relation("CircleApplicationReviewer")
  circleFollows        CircleFollow[]
  posts                Post[]                    @relation("PostAuthor")
  reviewedPosts        Post[]                    @relation("PostReviewer")
  postRevisions        PostRevision[]
  postAttachments      PostAttachment[]          @relation("PostAttachmentUploader")
  comments             Comment[]                 @relation("CommentAuthor")
  reviewedComments     Comment[]                 @relation("CommentReviewer")
  commentRevisions     CommentRevision[]
  reactions            Reaction[]
  favorites            Favorite[]
  pollVotes            PollVote[]
  createdConversations Conversation[]            @relation("ConversationCreator")
  conversationMembers  ConversationParticipant[]
  sentMessages         Message[]                 @relation("MessageSender")
  notifications        Notification[]
  reports              Report[]                  @relation("ReportReporter")
  assignedReports      Report[]                  @relation("ReportAssignee")
  resolvedReports      Report[]                  @relation("ReportResolver")
  moderationActions    ModerationAction[]        @relation("ModerationActor")
  moderatedTargets     ModerationAction[]        @relation("ModerationTargetUser")
  pointLedgers         PointLedger[]             @relation("PointLedgerUser")
  pointAdjustments     PointLedger[]             @relation("PointLedgerOperator")
  userBadges           UserBadge[]               @relation("UserBadgeOwner")
  grantedBadges        UserBadge[]               @relation("UserBadgeGranter")
  auditLogs            AuditLog[]
  deletionRequests     AccountDeletionRequest[]  @relation("DeletionRequestUser")
  reviewedDeletions    AccountDeletionRequest[]  @relation("DeletionRequestReviewer")

  @@index([status])
  @@index([role])
  @@map("users")
}

model UserProfile {
  id              String    @id @default(cuid())
  userId          String    @unique @map("user_id")
  nickname        String
  avatarUrl       String?   @map("avatar_url")
  bio             String?
  points          Int       @default(0)
  featuredBadgeId String?   @map("featured_badge_id")
  titleBadgeId    String?   @map("title_badge_id")
  lastActiveAt    DateTime? @map("last_active_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  featuredBadge   Badge?    @relation("FeaturedBadge", fields: [featuredBadgeId], references: [id], onDelete: SetNull)
  titleBadge      Badge?    @relation("TitleBadge", fields: [titleBadgeId], references: [id], onDelete: SetNull)

  @@index([nickname])
  @@map("user_profiles")
}

model UserSetting {
  id                      String                  @id @default(cuid())
  userId                  String                  @unique @map("user_id")
  directMessagePermission DirectMessagePermission @default(FOLLOWING_ONLY) @map("direct_message_permission")
  homepageLastFeedChannel HomeFeedChannel         @default(RECOMMENDED) @map("homepage_last_feed_channel")
  notificationsLastReadAt DateTime?               @map("notifications_last_read_at")
  allowAnonymousPosts     Boolean                 @default(true) @map("allow_anonymous_posts")
  allowAnonymousComments  Boolean                 @default(true) @map("allow_anonymous_comments")
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @updatedAt @map("updated_at")
  user                    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")
  follower    User     @relation("FollowingRelations", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("FollowerRelations", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("user_follows")
}

model UserBlock {
  id          String   @id @default(cuid())
  blockerId   String   @map("blocker_id")
  blockedId   String   @map("blocked_id")
  createdAt   DateTime @default(now()) @map("created_at")
  blocker     User     @relation("BlockingRelations", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedUser User     @relation("BlockedByRelations", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("user_blocks")
}

model AccountDeletionRequest {
  id           String         @id @default(cuid())
  userId       String         @map("user_id")
  status       WorkflowStatus @default(PENDING)
  reason       String?
  reviewNote   String?        @map("review_note")
  reviewedById String?        @map("reviewed_by_id")
  reviewedAt   DateTime?      @map("reviewed_at")
  anonymizedAt DateTime?      @map("anonymized_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  user         User           @relation("DeletionRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy   User?          @relation("DeletionRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@map("account_deletion_requests")
}

model CircleCategory {
  id           String              @id @default(cuid())
  name         String
  slug         String              @unique
  description  String?
  sortOrder    Int                 @default(0) @map("sort_order")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  circles      Circle[]
  applications CircleApplication[]

  @@map("circle_categories")
}

model Circle {
  id             String                  @id @default(cuid())
  categoryId     String                  @map("category_id")
  name           String
  slug           String                  @unique
  coverUrl       String?                 @map("cover_url")
  iconUrl        String?                 @map("icon_url")
  intro          String?
  rules          String?
  announcement   String?
  allowAnonymous Boolean                 @default(false) @map("allow_anonymous")
  status         CircleStatus            @default(PENDING_REVIEW)
  ownerId        String?                 @map("owner_id")
  followersCount Int                     @default(0) @map("followers_count")
  postsCount     Int                     @default(0) @map("posts_count")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  deletedAt      DateTime?               @map("deleted_at")
  category       CircleCategory          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  owner          User?                   @relation("CircleOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  managers       CircleManagerRelation[]
  applications   CircleApplication[]
  follows        CircleFollow[]
  tags           Tag[]
  posts          Post[]

  @@unique([categoryId, name])
  @@index([status, categoryId])
  @@index([ownerId])
  @@map("circles")
}

model CircleManagerRelation {
  id          String            @id @default(cuid())
  circleId    String            @map("circle_id")
  userId      String            @map("user_id")
  role        CircleManagerRole
  grantedById String?           @map("granted_by_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  circle      Circle            @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user        User              @relation("CircleManagerUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy   User?             @relation("CircleManagerGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([circleId, userId])
  @@index([userId])
  @@map("circle_manager_relations")
}

model CircleApplication {
  id             String         @id @default(cuid())
  applicantId    String         @map("applicant_id")
  categoryId     String         @map("category_id")
  circleId       String?        @map("circle_id")
  reviewerId     String?        @map("reviewer_id")
  name           String
  slug           String
  coverUrl       String?        @map("cover_url")
  iconUrl        String?        @map("icon_url")
  intro          String?
  rules          String?
  allowAnonymous Boolean        @default(false) @map("allow_anonymous")
  status         WorkflowStatus @default(PENDING)
  reviewNote     String?        @map("review_note")
  reviewedAt     DateTime?      @map("reviewed_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  applicant      User           @relation("CircleApplicationApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  category       CircleCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  circle         Circle?        @relation(fields: [circleId], references: [id], onDelete: SetNull)
  reviewer       User?          @relation("CircleApplicationReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@unique([slug, status])
  @@index([status, createdAt])
  @@map("circle_applications")
}

model CircleFollow {
  id        String   @id @default(cuid())
  circleId  String   @map("circle_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  circle    Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([circleId, userId])
  @@index([userId])
  @@map("circle_follows")
}

model Tag {
  id          String    @id @default(cuid())
  circleId    String?   @map("circle_id")
  name        String
  slug        String
  description String?
  scope       TagScope  @default(GLOBAL)
  isHot       Boolean   @default(false) @map("is_hot")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  circle      Circle?   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  postTags    PostTag[]

  @@unique([scope, circleId, slug])
  @@index([scope, isHot])
  @@map("tags")
}

model Post {
  id            String            @id @default(cuid())
  circleId      String            @map("circle_id")
  authorId      String            @map("author_id")
  reviewedById  String?           @map("reviewed_by_id")
  postType      PostType          @map("post_type")
  title         String
  excerpt       String?
  contentJson   Json              @map("content_json")
  contentHtml   String            @map("content_html")
  isAnonymous   Boolean           @default(false) @map("is_anonymous")
  visibility    ContentVisibility @default(PUBLIC)
  status        ContentStatus     @default(PENDING_REVIEW)
  isPinned      Boolean           @default(false) @map("is_pinned")
  isFeatured    Boolean           @default(false) @map("is_featured")
  isRecommended Boolean           @default(false) @map("is_recommended")
  scoreHot      Float             @default(0) @map("score_hot")
  viewCount     Int               @default(0) @map("view_count")
  commentCount  Int               @default(0) @map("comment_count")
  favoriteCount Int               @default(0) @map("favorite_count")
  reactionCount Int               @default(0) @map("reaction_count")
  reviewNote    String?           @map("review_note")
  reviewedAt    DateTime?         @map("reviewed_at")
  publishedAt   DateTime?         @map("published_at")
  deletedAt     DateTime?         @map("deleted_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  circle        Circle            @relation(fields: [circleId], references: [id], onDelete: Cascade)
  author        User              @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  reviewedBy    User?             @relation("PostReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  revisions     PostRevision[]
  tags          PostTag[]
  attachments   PostAttachment[]
  comments      Comment[]
  poll          Poll?
  favorites     Favorite[]

  @@index([circleId, status, createdAt])
  @@index([authorId, createdAt])
  @@index([status, scoreHot])
  @@map("posts")
}

model PostRevision {
  id          String   @id @default(cuid())
  postId      String   @map("post_id")
  editorId    String   @map("editor_id")
  title       String
  contentJson Json     @map("content_json")
  contentHtml String   @map("content_html")
  createdAt   DateTime @default(now()) @map("created_at")
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  editor      User     @relation(fields: [editorId], references: [id], onDelete: Restrict)

  @@index([postId, createdAt])
  @@map("post_revisions")
}

model PostTag {
  postId    String   @map("post_id")
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("post_tags")
}

model PostAttachment {
  id           String         @id @default(cuid())
  postId       String         @map("post_id")
  uploaderId   String         @map("uploader_id")
  kind         AttachmentKind
  originalName String         @map("original_name")
  fileName     String         @map("file_name")
  mimeType     String         @map("mime_type")
  extension    String
  storagePath  String         @map("storage_path")
  accessUrl    String?        @map("access_url")
  sizeBytes    Int            @map("size_bytes")
  createdAt    DateTime       @default(now()) @map("created_at")
  post         Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  uploader     User           @relation("PostAttachmentUploader", fields: [uploaderId], references: [id], onDelete: Restrict)

  @@index([postId])
  @@map("post_attachments")
}

model Comment {
  id            String            @id @default(cuid())
  postId        String            @map("post_id")
  authorId      String            @map("author_id")
  reviewedById  String?           @map("reviewed_by_id")
  parentId      String?           @map("parent_id")
  rootId        String?           @map("root_id")
  contentJson   Json              @map("content_json")
  contentHtml   String            @map("content_html")
  isAnonymous   Boolean           @default(false) @map("is_anonymous")
  status        ContentStatus     @default(PENDING_REVIEW)
  reactionCount Int               @default(0) @map("reaction_count")
  replyCount    Int               @default(0) @map("reply_count")
  reviewNote    String?           @map("review_note")
  reviewedAt    DateTime?         @map("reviewed_at")
  deletedAt     DateTime?         @map("deleted_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  post          Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  author        User              @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  reviewedBy    User?             @relation("CommentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  parent        Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]         @relation("CommentReplies")
  root          Comment?          @relation("CommentRoot", fields: [rootId], references: [id], onDelete: Cascade)
  threadedItems Comment[]         @relation("CommentRoot")
  revisions     CommentRevision[]

  @@index([postId, status, createdAt])
  @@index([parentId])
  @@index([rootId])
  @@map("comments")
}

model CommentRevision {
  id          String   @id @default(cuid())
  commentId   String   @map("comment_id")
  editorId    String   @map("editor_id")
  contentJson Json     @map("content_json")
  contentHtml String   @map("content_html")
  createdAt   DateTime @default(now()) @map("created_at")
  comment     Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  editor      User     @relation(fields: [editorId], references: [id], onDelete: Restrict)

  @@index([commentId, createdAt])
  @@map("comment_revisions")
}

model Reaction {
  id           String             @id @default(cuid())
  userId       String             @map("user_id")
  targetType   ReactionTargetType @map("target_type")
  targetId     String             @map("target_id")
  reactionType ReactionType       @map("reaction_type")
  emojiCode    String?            @map("emoji_code")
  createdAt    DateTime           @default(now()) @map("created_at")
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId, reactionType, emojiCode])
  @@index([targetType, targetId])
  @@map("reactions")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  postId    String   @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@map("favorites")
}

model Poll {
  id               String               @id @default(cuid())
  postId           String               @unique @map("post_id")
  question         String?
  allowMultiple    Boolean              @default(false) @map("allow_multiple")
  resultVisibility PollResultVisibility @default(ALWAYS_PUBLIC) @map("result_visibility")
  expiresAt        DateTime?            @map("expires_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  post             Post                 @relation(fields: [postId], references: [id], onDelete: Cascade)
  options          PollOption[]
  votes            PollVote[]

  @@map("polls")
}

model PollOption {
  id        String     @id @default(cuid())
  pollId    String     @map("poll_id")
  label     String
  sortOrder Int        @default(0) @map("sort_order")
  voteCount Int        @default(0) @map("vote_count")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     PollVote[]

  @@index([pollId, sortOrder])
  @@map("poll_options")
}

model PollVote {
  id        String     @id @default(cuid())
  pollId    String     @map("poll_id")
  optionId  String     @map("option_id")
  userId    String     @map("user_id")
  createdAt DateTime   @default(now()) @map("created_at")
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, optionId, userId])
  @@index([userId])
  @@map("poll_votes")
}

model Conversation {
  id               String                    @id @default(cuid())
  conversationType ConversationType          @default(DIRECT) @map("conversation_type")
  title            String?
  createdById      String?                   @map("created_by_id")
  lastMessageAt    DateTime?                 @map("last_message_at")
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")
  createdBy        User?                     @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  participants     ConversationParticipant[]
  messages         Message[]

  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationParticipant {
  id                String       @id @default(cuid())
  conversationId    String       @map("conversation_id")
  userId            String       @map("user_id")
  lastReadMessageId String?      @map("last_read_message_id")
  lastReadAt        DateTime?    @map("last_read_at")
  joinedAt          DateTime     @default(now()) @map("joined_at")
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadMessage   Message?     @relation("LastReadMessage", fields: [lastReadMessageId], references: [id], onDelete: SetNull)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id                 String                    @id @default(cuid())
  conversationId     String                    @map("conversation_id")
  senderId           String                    @map("sender_id")
  messageType        MessageType               @default(TEXT) @map("message_type")
  contentText        String?                   @map("content_text")
  contentJson        Json?                     @map("content_json")
  isDeleted          Boolean                   @default(false) @map("is_deleted")
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")
  conversation       Conversation              @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender             User                      @relation("MessageSender", fields: [senderId], references: [id], onDelete: Restrict)
  readByParticipants ConversationParticipant[] @relation("LastReadMessage")

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@map("messages")
}

model Notification {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  type        NotificationType
  payloadJson Json             @map("payload_json")
  isRead      Boolean          @default(false) @map("is_read")
  readAt      DateTime?        @map("read_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model Report {
  id                String             @id @default(cuid())
  reporterId        String             @map("reporter_id")
  assigneeId        String?            @map("assignee_id")
  resolverId        String?            @map("resolver_id")
  targetType        ReportTargetType   @map("target_type")
  targetId          String             @map("target_id")
  reportType        ReportType         @map("report_type")
  detail            String?
  status            ReportStatus       @default(PENDING)
  resolutionNote    String?            @map("resolution_note")
  resolvedAt        DateTime?          @map("resolved_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  reporter          User               @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  assignee          User?              @relation("ReportAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  resolver          User?              @relation("ReportResolver", fields: [resolverId], references: [id], onDelete: SetNull)
  moderationActions ModerationAction[]

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@map("reports")
}

model ModerationAction {
  id           String               @id @default(cuid())
  actorId      String               @map("actor_id")
  targetUserId String?              @map("target_user_id")
  reportId     String?              @map("report_id")
  actionType   ModerationActionType @map("action_type")
  targetType   ReportTargetType?    @map("target_type")
  targetId     String?              @map("target_id")
  reason       String?
  metadataJson Json?                @map("metadata_json")
  createdAt    DateTime             @default(now()) @map("created_at")
  actor        User                 @relation("ModerationActor", fields: [actorId], references: [id], onDelete: Restrict)
  targetUser   User?                @relation("ModerationTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  report       Report?              @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([actionType, createdAt])
  @@index([targetType, targetId])
  @@map("moderation_actions")
}

model SensitiveWord {
  id        String              @id @default(cuid())
  word      String              @unique
  level     SensitiveWordLevel
  action    SensitiveWordAction
  note      String?
  isActive  Boolean             @default(true) @map("is_active")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  @@index([isActive, level])
  @@map("sensitive_words")
}

model PointRule {
  id          String         @id @default(cuid())
  eventType   PointEventType @map("event_type")
  name        String         @unique
  description String?
  points      Int
  dailyLimit  Int?           @map("daily_limit")
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  ledgers     PointLedger[]

  @@index([eventType, isActive])
  @@map("point_rules")
}

model PointLedger {
  id            String         @id @default(cuid())
  userId        String         @map("user_id")
  ruleId        String?        @map("rule_id")
  operatorId    String?        @map("operator_id")
  eventType     PointEventType @map("event_type")
  delta         Int
  balanceAfter  Int            @map("balance_after")
  referenceType String?        @map("reference_type")
  referenceId   String?        @map("reference_id")
  note          String?
  createdAt     DateTime       @default(now()) @map("created_at")
  user          User           @relation("PointLedgerUser", fields: [userId], references: [id], onDelete: Cascade)
  rule          PointRule?     @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  operator      User?          @relation("PointLedgerOperator", fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([referenceType, referenceId])
  @@map("point_ledger")
}

model Badge {
  id               String        @id @default(cuid())
  name             String        @unique
  description      String?
  iconUrl          String?       @map("icon_url")
  kind             BadgeKind     @default(BADGE)
  grantCondition   String?       @map("grant_condition")
  isActive         Boolean       @default(true) @map("is_active")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  userBadges       UserBadge[]
  featuredProfiles UserProfile[] @relation("FeaturedBadge")
  titleProfiles    UserProfile[] @relation("TitleBadge")

  @@index([kind, isActive])
  @@map("badges")
}

model UserBadge {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  badgeId     String    @map("badge_id")
  grantedById String?   @map("granted_by_id")
  reason      String?
  expiresAt   DateTime? @map("expires_at")
  grantedAt   DateTime  @default(now()) @map("granted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation("UserBadgeOwner", fields: [userId], references: [id], onDelete: Cascade)
  badge       Badge     @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  grantedBy   User?     @relation("UserBadgeGranter", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, badgeId])
  @@index([badgeId])
  @@map("user_badges")
}

model Banner {
  id        String       @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String       @map("image_url")
  linkUrl   String?      @map("link_url")
  sortOrder Int          @default(0) @map("sort_order")
  status    BannerStatus @default(DRAFT)
  startsAt  DateTime?    @map("starts_at")
  endsAt    DateTime?    @map("ends_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@index([status, sortOrder])
  @@map("banners")
}

model RecommendationSlot {
  id          String                   @id @default(cuid())
  slotType    RecommendationSlotType   @map("slot_type")
  targetType  RecommendationTargetType @map("target_type")
  title       String
  description String?
  targetId    String?                  @map("target_id")
  imageUrl    String?                  @map("image_url")
  linkUrl     String?                  @map("link_url")
  sortOrder   Int                      @default(0) @map("sort_order")
  isActive    Boolean                  @default(true) @map("is_active")
  startsAt    DateTime?                @map("starts_at")
  endsAt      DateTime?                @map("ends_at")
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")

  @@index([slotType, isActive, sortOrder])
  @@map("recommendation_slots")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?  @map("actor_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  payloadJson Json?    @map("payload_json")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")
  actor       User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

model DailyStat {
  id          String   @id @default(cuid())
  statDate    DateTime @unique @map("stat_date") @db.Date
  newUsers    Int      @default(0) @map("new_users")
  newPosts    Int      @default(0) @map("new_posts")
  newComments Int      @default(0) @map("new_comments")
  newReports  Int      @default(0) @map("new_reports")
  activeUsers Int      @default(0) @map("active_users")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("daily_stats")
}
